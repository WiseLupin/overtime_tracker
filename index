<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>교사 초과근무 계산기</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Pretendard:wght@400;600;700&display=swap');
        body { font-family: 'Pretendard', sans-serif; }
    </style>
</head>
<body class="bg-slate-50 min-h-screen py-8 px-4">
    <div class="max-w-2xl mx-auto">
        <!-- -->
        <header class="mb-8">
            <h1 class="text-3xl font-bold text-slate-800">초과근무 관리</h1>
            <p class="text-slate-500 mt-1">분 단위까지 정확하게 관리하세요.</p>
        </header>

        <!-- -->
        <div class="mb-6 flex justify-between items-center bg-white p-4 rounded-2xl shadow-sm border border-slate-200">
            <label class="text-sm font-semibold text-slate-500">기준 월 선택</label>
            <input type="month" id="monthFilter" onchange="render()" class="font-bold text-slate-800 outline-none">
        </div>

        <!-- -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 mb-6">
            <div class="grid grid-cols-2 gap-4 mb-4">
                <div>
                    <label class="block text-xs font-semibold text-slate-400 uppercase mb-1">날짜</label>
                    <input type="date" id="dateInput" class="w-full bg-slate-50 border border-slate-200 rounded-lg p-2.5 outline-none focus:ring-2 focus:ring-blue-500">
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-400 uppercase mb-1">퇴근 시간</label>
                    <input type="time" id="timeInput" class="w-full bg-slate-50 border border-slate-200 rounded-lg p-2.5 outline-none focus:ring-2 focus:ring-blue-500">
                </div>
            </div>
            
            <div class="flex items-center gap-4 mb-6">
                <label class="flex items-center text-sm font-medium text-slate-700 cursor-pointer">
                    <input type="checkbox" id="isWeekend" class="w-4 h-4 rounded border-slate-300 mr-2 text-blue-600"> 주말/공휴일
                </label>
                <label class="flex items-center text-sm font-medium text-slate-700 cursor-pointer">
                    <input type="checkbox" id="isSupplementary" class="w-4 h-4 rounded border-slate-300 mr-2 text-blue-600"> 보충수업(100분)
                </label>
            </div>

            <button onclick="addRecord()" class="w-full bg-slate-900 text-white font-semibold py-3 rounded-xl hover:bg-slate-800 transition-all active:scale-[0.98]">
                기록 추가하기
            </button>
        </div>

        <!-- -->
        <div class="bg-blue-600 rounded-2xl p-6 text-white mb-6 shadow-lg shadow-blue-200">
            <h2 class="text-blue-100 text-sm font-medium mb-1" id="currentMonthLabel">이번 달 누적 초과근무</h2>
            <div id="totalDisplay" class="text-4xl font-bold tracking-tight">0시간 0분</div>
            <p class="text-blue-200 text-xs mt-3 opacity-80">※ 하루 최대 4시간까지 인정됩니다.</p>
        </div>

        <!-- -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-100 flex justify-between items-center">
                <h3 class="font-semibold text-slate-800">기록 리스트</h3>
                <div class="flex gap-2">
                    <button onclick="undoDelete()" id="undoBtn" class="text-xs text-slate-500 hover:text-blue-600 hidden">삭제 복원</button>
                    <button onclick="resetMonth()" class="text-xs text-red-500 hover:text-red-700">해당 월 삭제</button>
                </div>
            </div>
            <div id="recordTable" class="divide-y divide-slate-100"></div>
        </div>
    </div>

    <!-- -->
    <script>
        let records = JSON.parse(localStorage.getItem('overtime_records')) || [];
        let deletedRecords = [];

        function init() {
            // 오늘 날짜 설정
            const today = new Date();
            document.getElementById('dateInput').valueAsDate = today;
            document.getElementById('timeInput').value = today.toTimeString().slice(0, 5);
            
            // 월 선택 초기값 (YYYY-MM)
            document.getElementById('monthFilter').value = today.toISOString().slice(0, 7);
            render();
        }

        function calculateTime(timeStr, isWeekend, isSupplementary) {
            const [h, m] = timeStr.split(':').map(Number);
            const totalMinutes = h * 60 + m;
            const endWork = 16 * 60 + 30; // 16:30
            
            if (totalMinutes <= endWork) return 0;
            
            let workMinutes = totalMinutes - endWork;
            if (!isWeekend) workMinutes -= 60; // 기본 공제 1시간
            if (isSupplementary) workMinutes -= 100; // 보충수업 공제
            
            let finalMinutes = Math.max(0, workMinutes);
            return Math.min(finalMinutes, 240); // 하루 최대 4시간(240분)
        }

        function addRecord() {
            const date = document.getElementById('dateInput').value;
            const time = document.getElementById('timeInput').value;
            const isWeekend = document.getElementById('isWeekend').checked;
            const isSupplementary = document.getElementById('isSupplementary').checked;
            
            const minutes = calculateTime(time, isWeekend, isSupplementary);
            records.push({ date, time, minutes, isWeekend, isSupplementary });
            
            // 추가한 날짜의 월로 자동 전환
            document.getElementById('monthFilter').value = date.slice(0, 7);
            save();
            render();
        }

        function save() {
            localStorage.setItem('overtime_records', JSON.stringify(records));
        }

        function deleteRecord(index) {
            // 현재 화면에 보이는 리스트 기준이 아니라, 전체 배열 기준으로 삭제
            // 필터링된 배열에서 클릭했으므로, 필터링 된 인덱스를 전체로 매핑해야 함
            const month = document.getElementById('monthFilter').value;
            const filteredIndices = records
                .map((r, i) => r.date.startsWith(month) ? i : -1)
                .filter(i => i !== -1);
            
            const originalIndex = filteredIndices[index];
            deletedRecords = [records[originalIndex]];
            records.splice(originalIndex, 1);
            save();
            render();
        }

        function undoDelete() {
            if (deletedRecords.length > 0) {
                records.push(deletedRecords[0]);
                deletedRecords = [];
                save();
                render();
            }
        }

        function resetMonth() {
            const month = document.getElementById('monthFilter').value;
            if(confirm(`${month}월의 모든 기록을 삭제할까요?`)) {
                records = records.filter(r => !r.date.startsWith(month));
                save();
                render();
            }
        }

        function render() {
            const container = document.getElementById('recordTable');
            const month = document.getElementById('monthFilter').value;
            container.innerHTML = '';
            
            const filteredRecords = records.filter(r => r.date.startsWith(month));
            let total = 0;
            
            document.getElementById('currentMonthLabel').innerText = `${month} 누적 초과근무`;

            if (filteredRecords.length === 0) {
                container.innerHTML = `<p class="p-6 text-center text-slate-400 text-sm">기록된 초과근무가 없습니다.</p>`;
            } else {
                filteredRecords.forEach((r, i) => {
                    total += r.minutes;
                    const tag = r.isWeekend ? '주말' : (r.isSupplementary ? '보충' : '일반');
                    container.innerHTML += `
                        <div class="px-6 py-4 flex items-center justify-between hover:bg-slate-50 transition-colors">
                            <div>
                                <p class="text-sm font-semibold text-slate-800">${r.date} (${r.time} 퇴근)</p>
                                <p class="text-xs text-slate-500">${tag} / ${Math.floor(r.minutes/60)}시간 ${r.minutes%60}분 인정</p>
                            </div>
                            <button onclick="deleteRecord(${i})" class="text-slate-300 hover:text-red-500">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" /></svg>
                            </button>
                        </div>
                    `;
                });
            }
            document.getElementById('totalDisplay').innerText = `${Math.floor(total/60)}시간 ${total%60}분`;
            document.getElementById('undoBtn').classList.toggle('hidden', deletedRecords.length === 0);
        }

        init();
    </script>
</body>
</html>
